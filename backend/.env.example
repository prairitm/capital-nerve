DATABASE_URL=postgresql+psycopg://capitalnerve:capitalnerve@db:5432/capitalnerve
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
APP_ENV=dev

# --- Optional admin bootstrap ---
# If both vars are set, the catalog seeder creates this admin on first boot.
# Leave blank to skip; users can also sign up via POST /auth/signup.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# --- Ingestion pipeline ---
STORAGE_DIR=var/storage
# LLM_PROVIDER=mock is the deterministic regex fallback for local dev. It is
# rejected at startup when APP_ENV=production. Set to 'anthropic' or
# 'openai' (with the matching API key) for real structured extraction.
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
# Optional cheap-tier model used for non-financial-result documents
# (transcripts, press releases, presentations, annual reports). When unset,
# all document types route through LLM_MODEL.
LLM_MODEL_FAST=
ANTHROPIC_API_KEY=
# When LLM_PROVIDER=openai, set LLM_MODEL to an OpenAI model (e.g. gpt-5.4-mini).
OPENAI_API_KEY=
WORKER_POLL_INTERVAL_SECONDS=2.0
WORKER_INPROCESS=true
AUTO_PUBLISH_CONFIDENCE=80.0

# --- Document search / RAG ---
# EMBEDDING_PROVIDER=mock skips vector indexing; RAG falls back to FTS-only retrieval.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=8
RAG_MAX_CHUNK_CHARS=2500

# --- IR discovery agent (used by `python -m app.scripts.bulk_ingest`) ---
# OpenAI Agents SDK + WebSearchTool. Reuses OPENAI_API_KEY above.
IR_AGENT_MODEL=gpt-5.5
IR_AGENT_CONCURRENCY=4
IR_AGENT_RUNS_DIR=var/ingest_runs

# --- Exchange (BSE / NSE) IR discovery ---
# How long the on-disk BSE listed-equity master-list cache (var/bse_master/equity.json)
# is reused before it's refreshed from api.bseindia.com.
BSE_MASTER_TTL_DAYS=7
