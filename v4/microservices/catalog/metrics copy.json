  "cfo_to_pat": {
    "name": "CFO To PAT",
    "unit": "x",
    "category": "cash_quality",
    "formula": "cfo/pat",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "pat",
        "fact_key": "pat",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pat>0"
  },
  "cfo_to_ebitda": {
    "name": "CFO To EBITDA",
    "unit": "x",
