        "fact_key": "ebitda",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "ebitda>0"
  },
  "free_cash_flow": {
    "name": "Free Cash Flow",
    "unit": "crore",
    "category": "cash_flow",
    "formula": "cfo-capex",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "capex",
        "fact_key": "purchase_of_ppe_and_intangibles",
        "scope": "CURRENT"
      }
    ]
  },
  "free_cash_flow_margin": {
    "name": "Free Cash Flow Margin",
    "unit": "%",
    "category": "cash_flow",
    "formula": "(cfo-capex)/revenue*100",
