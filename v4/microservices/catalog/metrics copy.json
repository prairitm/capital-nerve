{
  "revenue_yoy_growth": {
    "name": "Revenue YoY Growth",
    "unit": "%",
    "category": "growth",
    "formula": "(revenue-revenue_py)/abs(revenue_py)*100",
    "inputs": [
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "revenue_py",
        "fact_key": "revenue_from_operations",
        "scope": "PY"
      }
    ]
  },
