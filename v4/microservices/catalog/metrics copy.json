  "other_income_to_pbt": {
    "name": "Other Income To PBT",
    "unit": "%",
    "category": "earnings_quality",
    "formula": "other_income/abs(pbt)*100",
    "inputs": [
      {
        "var": "other_income",
        "fact_key": "other_income",
        "scope": "CURRENT"
      },
      {
        "var": "pbt",
        "fact_key": "pbt",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pbt!=0"
  },
