    "name": "EBIT Interest Coverage",
    "unit": "x",
    "category": "leverage",
    "formula": "ebit/finance_cost",
    "inputs": [
      {
        "var": "ebit",
        "fact_key": "ebit",
        "scope": "CURRENT"
      },
      {
        "var": "finance_cost",
        "fact_key": "finance_cost",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "finance_cost>0"
  },
  "current_ratio": {
    "name": "Current Ratio",
    "unit": "x",
    "category": "liquidity",
    "formula": "current_assets/current_liabilities",
    "inputs": [
      {
        "var": "current_assets",
        "fact_key": "total_current_assets",
        "scope": "CURRENT"
      },
      {
        "var": "current_liabilities",
        "fact_key": "total_current_liabilities",
        "scope": "CURRENT"
      }
    ]
  },
