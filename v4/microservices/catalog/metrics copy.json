    "name": "Debt To Equity",
    "unit": "x",
    "category": "leverage",
    "formula": "gross_debt/equity",
    "inputs": [
      {
        "var": "gross_debt",
        "metric_key": "gross_debt"
      },
      {
        "var": "equity",
        "fact_key": "total_equity",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "equity>0"
  },
