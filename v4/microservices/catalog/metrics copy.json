  "ebitda_margin": {
    "name": "EBITDA Margin",
    "unit": "%",
    "category": "margin",
    "formula": "ebitda/revenue*100",
    "inputs": [
      {
        "var": "ebitda",
        "fact_key": "ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  },
  "ebitda_margin_change_yoy_bps": {
    "name": "EBITDA Margin Change YoY Bps",
    "unit": "bps",
    "category": "margin",
    "formula": "(ebitda/revenue-ebitda_py/revenue_py)*10000",
    "inputs": [
      {
        "var": "ebitda",
        "fact_key": "ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "ebitda_py",
        "fact_key": "ebitda",
        "scope": "PY"
      },
      {
        "var": "revenue_py",
        "fact_key": "revenue_from_operations",
        "scope": "PY"
      }
    ]
  },
