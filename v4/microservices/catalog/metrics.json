  "pat_margin": {
    "name": "PAT Margin",
    "unit": "%",
    "category": "margin",
    "formula": "pat/revenue*100",
    "inputs": [
      {
        "var": "pat",
        "fact_key": "pat",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  },
  "other_income_to_pbt": {
    "name": "Other Income To PBT",
    "unit": "%",
    "category": "earnings_quality",
    "formula": "other_income/abs(pbt)*100",
    "inputs": [
      {
        "var": "other_income",
        "fact_key": "other_income",
        "scope": "CURRENT"
      },
      {
        "var": "pbt",
        "fact_key": "pbt",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pbt!=0"
  },
  // "other_income_to_total_income": {
  //   "name": "Other Income To Total Income",
  //   "unit": "%",
  //   "category": "earnings_quality",
  //   "formula": "other_income/total_income*100",
  //   "inputs": [
