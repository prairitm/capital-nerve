  "exceptional_to_pbt": {
    "name": "Exceptional To PBT",
    "unit": "%",
    "category": "earnings_quality",
    "formula": "abs(exceptional)/abs(pbt)*100",
    "inputs": [
      {
        "var": "exceptional",
        "fact_key": "exceptional_items",
        "scope": "CURRENT"
      },
      {
        "var": "pbt",
        "fact_key": "pbt",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pbt!=0"
  },
  "effective_tax_rate": {
    "name": "Effective Tax Rate",
    "unit": "%",
    "category": "tax",
    "formula": "tax/pbt*100",
    "inputs": [
      {
        "var": "tax",
        "fact_key": "tax_expense",
        "scope": "CURRENT"
      },
      {
        "var": "pbt",
        "fact_key": "pbt",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pbt>0"
  },
  "cfo_to_pat": {
    "name": "CFO To PAT",
    "unit": "x",
    "category": "cash_quality",
    "formula": "cfo/pat",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "pat",
        "fact_key": "pat",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "pat>0"
  },
  "cfo_to_ebitda": {
    "name": "CFO To EBITDA",
    "unit": "x",
    "category": "cash_quality",
    "formula": "cfo/ebitda",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "ebitda",
        "fact_key": "ebitda",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "ebitda>0"
  },
  "free_cash_flow": {
    "name": "Free Cash Flow",
    "unit": "crore",
    "category": "cash_flow",
    "formula": "cfo-capex",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "capex",
        "fact_key": "purchase_of_ppe_and_intangibles",
        "scope": "CURRENT"
      }
    ]
  },
  "free_cash_flow_margin": {
    "name": "Free Cash Flow Margin",
    "unit": "%",
    "category": "cash_flow",
    "formula": "(cfo-capex)/revenue*100",
    "inputs": [
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      },
      {
        "var": "capex",
        "fact_key": "purchase_of_ppe_and_intangibles",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  },
  "capex_intensity": {
    "name": "Capex Intensity",
    "unit": "%",
    "category": "capital_allocation",
    "formula": "capex/revenue*100",
    "inputs": [
      {
        "var": "capex",
        "fact_key": "purchase_of_ppe_and_intangibles",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  },
  "net_borrowing_cash_flow": {
    "name": "Net Borrowing Cash Flow",
    "unit": "crore",
    "category": "financing",
    "formula": "raised-repaid",
    "inputs": [
      {
        "var": "raised",
        "fact_key": "borrowings_raised",
        "scope": "CURRENT"
      },
      {
        "var": "repaid",
        "fact_key": "borrowings_repaid",
        "scope": "CURRENT"
      }
    ]
  },
  "trade_payables_total": {
    "name": "Trade Payables Total",
    "unit": "crore",
    "category": "working_capital",
    "formula": "payables_msme+payables_other",
    "inputs": [
      {
        "var": "payables_msme",
        "fact_key": "trade_payables_msme",
        "scope": "CURRENT"
      },
      {
        "var": "payables_other",
        "fact_key": "trade_payables_other",
        "scope": "CURRENT"
      }
    ]
  },
  "receivables_yoy_growth": {
    "name": "Receivables YoY Growth",
    "unit": "%",
    "category": "working_capital",
    "formula": "(receivables-receivables_py)/abs(receivables_py)*100",
    "inputs": [
      {
        "var": "receivables",
        "fact_key": "trade_receivables",
        "scope": "CURRENT"
      },
      {
        "var": "receivables_py",
        "fact_key": "trade_receivables",
        "scope": "PY"
      }
    ]
  },
  "gross_debt": {
    "name": "Gross Debt",
    "unit": "crore",
    "category": "leverage",
    "formula": "ncb+cb+ncl+cl",
    "inputs": [
      {
        "var": "ncb",
        "fact_key": "non_current_borrowings",
        "scope": "CURRENT"
      },
      {
        "var": "cb",
        "fact_key": "current_borrowings",
        "scope": "CURRENT"
      },
      {
        "var": "ncl",
        "fact_key": "non_current_lease_liabilities",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "cl",
        "fact_key": "current_lease_liabilities",
        "scope": "CURRENT",
        "optional": true
      }
    ]
  },
  "net_debt": {
    "name": "Net Debt",
    "unit": "crore",
    "category": "leverage",
    "formula": "gross_debt-cash-bank-liquid_investments",
    "inputs": [
      {
        "var": "gross_debt",
        "metric_key": "gross_debt"
      },
      {
        "var": "cash",
        "fact_key": "cash_and_cash_equivalents",
        "scope": "CURRENT"
      },
      {
        "var": "bank",
        "fact_key": "other_bank_balances",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "liquid_investments",
        "fact_key": "current_investments",
        "scope": "CURRENT",
        "optional": true
      }
    ],
    "notes": "Exclude restricted balances and illiquid investments."
  },
  "gross_debt_yoy_growth": {
    "name": "Gross Debt YoY Growth",
    "unit": "%",
    "category": "leverage",
    "formula": "(debt-debt_py)/abs(debt_py)*100",
    "inputs": [
      {
        "var": "debt",
        "metric_key": "gross_debt"
      },
      {
        "var": "debt_py",
        "metric_key": "gross_debt",
        "scope": "PY"
      }
    ]
  },
  "ebit_interest_coverage": {
    "name": "EBIT Interest Coverage",
    "unit": "x",
    "category": "leverage",
    "formula": "ebit/finance_cost",
    "inputs": [
      {
        "var": "ebit",
        "fact_key": "ebit",
        "scope": "CURRENT"
      },
      {
        "var": "finance_cost",
        "fact_key": "finance_cost",
        "scope": "CURRENT"
      }
    ],
    "valid_when": "finance_cost>0"
  },
  "current_ratio": {
    "name": "Current Ratio",
    "unit": "x",
    "category": "liquidity",
    "formula": "current_assets/current_liabilities",
    "inputs": [
      {
        "var": "current_assets",
        "fact_key": "total_current_assets",
        "scope": "CURRENT"
      },
      {
        "var": "current_liabilities",
        "fact_key": "total_current_liabilities",
        "scope": "CURRENT"
      }
    ]
  },
  "short_term_debt_share": {
    "name": "Short Term Debt Share",
    "unit": "%",
    "category": "leverage",
    "formula": "(current_borrowings+current_lease)/gross_debt*100",
    "inputs": [
      {
        "var": "current_borrowings",
        "fact_key": "current_borrowings",
        "scope": "CURRENT"
      },
      {
        "var": "current_lease",
        "fact_key": "current_lease_liabilities",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "gross_debt",
        "metric_key": "gross_debt"
      }
    ]
  },
  "cash_to_gross_debt": {
    "name": "Cash To Gross Debt",
    "unit": "%",
    "category": "leverage",
    "formula": "(cash+bank+liquid_investments)/gross_debt*100",
    "inputs": [
      {
        "var": "cash",
        "fact_key": "cash_and_cash_equivalents",
        "scope": "CURRENT"
      },
      {
        "var": "bank",
        "fact_key": "other_bank_balances",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "liquid_investments",
        "fact_key": "current_investments",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "gross_debt",
        "metric_key": "gross_debt"
      }
    ]
  },
  "capital_employed": {
    "name": "Capital Employed",
    "unit": "crore",
    "category": "returns",
    "formula": "equity+gross_debt-cash-bank-liquid_investments",
    "inputs": [
      {
        "var": "equity",
        "fact_key": "total_equity",
        "scope": "CURRENT"
      },
      {
        "var": "gross_debt",
        "metric_key": "gross_debt"
      },
      {
        "var": "cash",
        "fact_key": "cash_and_cash_equivalents",
        "scope": "CURRENT"
      },
      {
        "var": "bank",
        "fact_key": "other_bank_balances",
        "scope": "CURRENT",
        "optional": true
      },
      {
        "var": "liquid_investments",
        "fact_key": "current_investments",
        "scope": "CURRENT",
        "optional": true
      }
    ]
  },
  "segment_revenue_yoy_growth": {
    "name": "Segment Revenue YoY Growth",
    "unit": "%",
    "category": "segment",
    "formula": "(segment_revenue-segment_revenue_py)/abs(segment_revenue_py)*100",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue_py",
        "fact_key": "segment_revenue",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_result_margin": {
    "name": "Segment Result Margin",
    "unit": "%",
    "category": "segment",
    "formula": "segment_result/segment_revenue*100",
    "inputs": [
      {
        "var": "segment_result",
        "fact_key": "segment_result",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_result_margin_change_yoy_bps": {
    "name": "Segment Result Margin Change YoY Bps",
    "unit": "bps",
    "category": "segment",
    "formula": "(segment_result/segment_revenue-segment_result_py/segment_revenue_py)*10000",
    "inputs": [
      {
        "var": "segment_result",
        "fact_key": "segment_result",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "segment_result_py",
        "fact_key": "segment_result",
        "scope": "PY"
      },
      {
        "var": "segment_revenue_py",
        "fact_key": "segment_revenue",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_revenue_mix": {
    "name": "Segment Revenue Mix",
    "unit": "%",
    "category": "segment",
    "formula": "segment_revenue/revenue*100",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "largest_segment_revenue_mix": {
    "name": "Largest Segment Revenue Mix",
    "unit": "%",
    "category": "concentration",
    "formula": "max_by_dimension(segment_revenue)/revenue*100",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ],
    "formula_type": "AGGREGATION"
  }
}