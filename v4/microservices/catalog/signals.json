{
  "revenue_contraction": {
    "name": "Revenue Contraction",
    "category": "growth",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "Revenue declined YoY.",
    "rule": {
      "metric_key": "revenue_yoy_growth",
      "op": "<",
      "value": 0
    }
  },
  "strong_revenue_growth": {
    "name": "Strong Revenue Growth",
    "category": "growth",
    "direction": "POSITIVE",
    "severity": "MEDIUM",
    "description": "Revenue grew above the baseline threshold.",
    "rule": {
      "metric_key": "revenue_yoy_growth",
      "op": ">",
      "value": 12
    },
    "threshold_profile_required": true
  },
  "ebitda_contraction": {
    "name": "EBITDA Contraction",
    "category": "growth",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "EBITDA declined YoY.",
    "rule": {
      "metric_key": "ebitda_yoy_growth",
      "op": "<",
      "value": 0
    }
  },
  "margin_expansion": {
    "name": "Margin Expansion",
    "category": "margin",
    "direction": "POSITIVE",
    "severity": "MEDIUM",
    "description": "EBITDA margin expanded materially YoY.",
    "rule": {
      "metric_key": "ebitda_margin_change_yoy_bps",
      "op": ">",
      "value": 75
    },
    "threshold_profile_required": true
  },
  "margin_compression": {
    "name": "Margin Compression",
    "category": "margin",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "EBITDA margin contracted materially YoY.",
    "rule": {
      "metric_key": "ebitda_margin_change_yoy_bps",
      "op": "<",
      "value": -75
    },
    "threshold_profile_required": true
  },
  "pat_decline_despite_revenue_growth": {
    "name": "PAT Decline Despite Revenue Growth",
    "category": "earnings_quality",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "Revenue grew but PAT declined.",
    "rule": {
      "all": [
        {
          "metric_key": "revenue_yoy_growth",
          "op": ">",
          "value": 0
        },
        {
          "metric_key": "pat_yoy_growth",
          "op": "<",
          "value": 0
        }
      ]
    }
  },
  "pat_growth_despite_ebitda_decline": {
    "name": "PAT Growth Despite EBITDA Decline",
    "category": "earnings_quality",
    "direction": "MIXED",
    "severity": "HIGH",
    "description": "PAT rose despite weaker operating profit.",
    "rule": {
      "all": [
        {
          "metric_key": "pat_yoy_growth",
          "op": ">",
          "value": 0
        },
        {
          "metric_key": "ebitda_yoy_growth",
          "op": "<",
          "value": 0
        }
      ]
    }
  },
  "other_income_dependency": {
    "name": "Other Income Dependency",
    "category": "earnings_quality",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "Other income forms a large share of PBT.",
    "rule": {
      "metric_key": "other_income_to_pbt",
      "op": ">",
      "value": 20
    },
    "threshold_profile_required": true
  },
  "interest_coverage_weakness": {
    "name": "Interest Coverage Weakness",
    "category": "leverage",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "EBIT does not comfortably cover finance costs.",
    "rule": {
      "metric_key": "ebit_interest_coverage",
      "op": "<",
      "value": 2.0
    }
  },
  "net_cash_balance_sheet": {
    "name": "Net Cash Balance Sheet",
    "category": "leverage",
    "direction": "POSITIVE",
    "severity": "MEDIUM",
    "description": "Cash and liquid balances exceed gross debt.",
    "rule": {
      "metric_key": "net_debt",
      "op": "<",
      "value": 0
    }
  },
  "qualified_review_conclusion": {
    "name": "Qualified Review Conclusion",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "The auditor or reviewer issued a qualified conclusion.",
    "rule": {
      "fact_key": "audit_conclusion",
      "op": "==",
      "value": "QUALIFIED"
    }
  },
  "adverse_or_disclaimer_conclusion": {
    "name": "Adverse Or Disclaimer Conclusion",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "CRITICAL",
    "description": "The auditor issued an adverse conclusion or disclaimer.",
    "rule": {
      "fact_key": "audit_conclusion",
      "op": "IN",
      "value": [
        "ADVERSE",
        "DISCLAIMER"
      ]
    }
  },
  "emphasis_of_matter": {
    "name": "Emphasis Of Matter",
    "category": "audit",
    "direction": "MIXED",
    "severity": "MEDIUM",
    "description": "The report contains an emphasis-of-matter paragraph.",
    "rule": {
      "fact_key": "emphasis_of_matter_flag",
      "op": "==",
      "value": true
    }
  },
  "going_concern_risk": {
    "name": "Going Concern Risk",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "CRITICAL",
    "description": "The auditor identified material uncertainty related to going concern.",
    "rule": {
      "fact_key": "going_concern_uncertainty_flag",
      "op": "==",
      "value": true
    }
  }
}