{
  "segment_ebitda_yoy_growth": {
    "name": "Segment EBITDA YoY Growth",
    "unit": "%",
    "category": "segment",
    "formula": "(segment_ebitda - segment_ebitda_py) / segment_ebitda_py * 100",
    "inputs": [
      {
        "var": "segment_ebitda",
        "fact_key": "segment_ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "segment_ebitda_py",
        "fact_key": "segment_ebitda",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_ebitda_margin": {
    "name": "Segment EBITDA Margin",
    "unit": "%",
    "category": "segment",
    "formula": "segment_ebitda / segment_revenue * 100",
    "inputs": [
      {
        "var": "segment_ebitda",
        "fact_key": "segment_ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_margin_change_yoy_bps": {
    "name": "Segment EBITDA Margin Change YoY",
    "unit": "bps",
    "category": "segment",
    "formula": "(segment_ebitda / segment_revenue - segment_ebitda_py / segment_revenue_py) * 10000",
    "inputs": [
      {
        "var": "segment_ebitda",
        "fact_key": "segment_ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "segment_ebitda_py",
        "fact_key": "segment_ebitda",
        "scope": "PY"
      },
      {
        "var": "segment_revenue_py",
        "fact_key": "segment_revenue",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_revenue_mix": {
    "name": "Segment Revenue Mix",
    "unit": "%",
    "category": "mix",
    "formula": "segment_revenue / revenue * 100",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "segment_mix_change_yoy_bps": {
    "name": "Segment Revenue Mix Change YoY",
    "unit": "bps",
    "category": "mix",
    "formula": "(segment_revenue / revenue - segment_revenue_py / revenue_py) * 10000",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "segment_revenue_py",
        "fact_key": "segment_revenue",
        "scope": "PY"
      },
      {
        "var": "revenue_py",
        "fact_key": "revenue_from_operations",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "revenue_guidance_revision_pct": {
    "name": "Revenue Guidance Revision",
    "unit": "%",
    "category": "guidance",
    "formula": "(((guidance_low + guidance_high) / 2) - ((prev_low + prev_high) / 2)) / ((prev_low + prev_high) / 2) * 100",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "revenue_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "revenue_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "prev_low",
        "fact_key": "revenue_guidance_low",
        "scope": "PREVIOUS_DISCLOSURE"
      },
      {
        "var": "prev_high",
        "fact_key": "revenue_guidance_high",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "ebitda_margin_guidance_revision_bps": {
    "name": "EBITDA Margin Guidance Revision",
    "unit": "bps",
    "category": "guidance",
    "formula": "(((guidance_low + guidance_high) / 2) - ((prev_low + prev_high) / 2)) * 100",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "ebitda_margin_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "ebitda_margin_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "prev_low",
        "fact_key": "ebitda_margin_guidance_low",
        "scope": "PREVIOUS_DISCLOSURE"
      },
      {
        "var": "prev_high",
        "fact_key": "ebitda_margin_guidance_high",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "largest_segment_revenue_mix": {
    "name": "Largest Segment Revenue Mix",
    "unit": "%",
    "category": "concentration",
    "formula": "max_by_dimension(segment_revenue) / revenue * 100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  },
  "segment_revenue_reconciliation_gap_pct": {
    "name": "Segment Revenue Reconciliation Gap",
    "unit": "%",
    "category": "data_quality",
    "formula": "(sum_by_dimension(segment_revenue) - revenue) / revenue * 100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "segment_revenue",
        "fact_key": "segment_revenue",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      }
    ]
  }
}
