    "inputs": [
      {
        "var": "capex",
        "fact_key": "capex_incurred",
        "scope": "CUMULATIVE"
      },
      {
        "var": "capex_plan",
        "fact_key": "capex_plan",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "capex_to_cfo": {
