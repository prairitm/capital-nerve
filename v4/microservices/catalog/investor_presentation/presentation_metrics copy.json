        "scope": "CURRENT"
      },
      {
        "var": "cfo",
        "fact_key": "cfo",
        "scope": "CURRENT"
      }
    ]
  },
  "capacity_expansion_pct": {
    "name": "Planned Capacity Expansion",
    "unit": "%",
    "category": "capital_allocation",
    "formula": "capacity_addition / capacity * 100",
    "inputs": [
      {
        "var": "capacity_addition",
        "fact_key": "capacity_addition_planned",
        "scope": "CURRENT"
      },
      {
        "var": "capacity",
        "fact_key": "installed_capacity",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "project_progress_change_pp": {
    "name": "Project Progress Change",
    "unit": "pp",
    "category": "project_execution",
    "formula": "completion - completion_pq",
    "inputs": [
      {
        "var": "completion",
        "fact_key": "project_completion_pct",
        "scope": "CURRENT"
      },
      {
        "var": "completion_pq",
        "fact_key": "project_completion_pct",
        "scope": "PQ"
      }
    ],
    "preserve_dimensions": true
  },
  "commissioning_delay_days": {
    "name": "Commissioning Date Slippage",
    "unit": "days",
    "category": "project_execution",
    "formula": "date_diff_days(expected_date, expected_date_previous)",
    "formula_type": "DATE",
    "inputs": [
      {
        "var": "expected_date",
        "fact_key": "expected_commissioning_date",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "expected_date_previous",
        "fact_key": "expected_commissioning_date",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "net_debt_yoy_change": {
    "name": "Net Debt YoY Change",
    "unit": "%",
    "category": "leverage",
    "formula": "(net_debt - net_debt_py) / abs(net_debt_py) * 100",
    "inputs": [
      {
        "var": "net_debt",
        "fact_key": "net_debt",
        "scope": "CURRENT"
      },
      {
        "var": "net_debt_py",
        "fact_key": "net_debt",
        "scope": "PY"
      }
    ]
  },
  "net_debt_to_annualized_ebitda": {
    "name": "Net Debt to Annualized EBITDA",
    "unit": "x",
    "category": "leverage",
    "formula": "net_debt / (ebitda * annualization_factor)",
    "inputs": [
      {
        "var": "net_debt",
        "fact_key": "net_debt",
        "scope": "CURRENT"
      },
      {
        "var": "ebitda",
        "fact_key": "ebitda",
        "scope": "CURRENT"
      },
      {
        "var": "annualization_factor",
        "constant": 4
      }
    ]
  },
  "revenue_guidance_midpoint": {
    "name": "Revenue Guidance Midpoint",
    "unit": "crore",
    "category": "guidance",
    "formula": "(guidance_low + guidance_high) / 2",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "revenue_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "revenue_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "revenue_growth_guidance_midpoint": {
    "name": "Revenue Growth Guidance Midpoint",
    "unit": "%",
    "category": "guidance",
    "formula": "(guidance_low + guidance_high) / 2",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "revenue_growth_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "revenue_growth_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "revenue_guidance_revision_pct": {
    "name": "Revenue Guidance Revision",
    "unit": "%",
    "category": "guidance",
    "formula": "(((guidance_low + guidance_high) / 2) - ((prev_low + prev_high) / 2)) / ((prev_low + prev_high) / 2) * 100",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "revenue_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "revenue_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "prev_low",
        "fact_key": "revenue_guidance_low",
        "scope": "PREVIOUS_DISCLOSURE"
      },
      {
        "var": "prev_high",
        "fact_key": "revenue_guidance_high",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "ebitda_margin_guidance_midpoint": {
    "name": "EBITDA Margin Guidance Midpoint",
    "unit": "%",
    "category": "guidance",
    "formula": "(guidance_low + guidance_high) / 2",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "ebitda_margin_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "ebitda_margin_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "ebitda_margin_guidance_revision_bps": {
    "name": "EBITDA Margin Guidance Revision",
    "unit": "bps",
    "category": "guidance",
    "formula": "(((guidance_low + guidance_high) / 2) - ((prev_low + prev_high) / 2)) * 100",
    "inputs": [
      {
        "var": "guidance_low",
        "fact_key": "ebitda_margin_guidance_low",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "guidance_high",
        "fact_key": "ebitda_margin_guidance_high",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "prev_low",
        "fact_key": "ebitda_margin_guidance_low",
        "scope": "PREVIOUS_DISCLOSURE"
      },
      {
        "var": "prev_high",
        "fact_key": "ebitda_margin_guidance_high",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "capex_guidance_achievement": {
    "name": "Capex Guidance Achievement",
    "unit": "%",
