  },
  "revenue_per_customer": {
    "name": "Revenue per Customer",
    "unit": "crore_per_customer",
    "category": "customer",
    "formula": "revenue / customers",
    "inputs": [
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "customers",
        "fact_key": "customer_count",
        "scope": "CURRENT"
      }
    ]
  },
  "revenue_per_customer_yoy_growth": {
    "name": "Revenue per Customer YoY Growth",
    "unit": "%",
    "category": "customer",
    "formula": "((revenue / customers) - (revenue_py / customers_py)) / (revenue_py / customers_py) * 100",
    "inputs": [
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "customers",
        "fact_key": "customer_count",
        "scope": "CURRENT"
      },
      {
        "var": "revenue_py",
        "fact_key": "revenue_from_operations",
        "scope": "PY"
      },
      {
        "var": "customers_py",
        "fact_key": "customer_count",
        "scope": "PY"
      }
    ]
  },
