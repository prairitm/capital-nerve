{
  "sales_volume_yoy_growth": {
    "name": "Sales Volume YoY Growth",
    "unit": "%",
    "category": "operating_growth",
    "formula": "(volume - volume_py) / volume_py * 100",
    "inputs": [
      {
        "var": "volume",
        "fact_key": "sales_volume",
        "scope": "CURRENT"
      },
      {
        "var": "volume_py",
        "fact_key": "sales_volume",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "production_volume_yoy_growth": {
    "name": "Production Volume YoY Growth",
    "unit": "%",
    "category": "operating_growth",
    "formula": "(production - production_py) / production_py * 100",
    "inputs": [
      {
        "var": "production",
        "fact_key": "production_volume",
        "scope": "CURRENT"
      },
      {
        "var": "production_py",
        "fact_key": "production_volume",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "realization_yoy_growth": {
    "name": "Average Realization YoY Growth",
    "unit": "%",
    "category": "pricing",
    "formula": "(realization - realization_py) / realization_py * 100",
    "inputs": [
      {
        "var": "realization",
        "fact_key": "average_realization",
        "scope": "CURRENT"
      },
      {
        "var": "realization_py",
        "fact_key": "average_realization",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "price_mix_contribution_yoy": {
    "name": "Implied Price/Mix Contribution",
    "unit": "pp",
    "category": "revenue_driver",
    "formula": "((revenue - revenue_py) / revenue_py * 100) - ((volume - volume_py) / volume_py * 100)",
    "inputs": [
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "revenue_py",
        "fact_key": "revenue_from_operations",
        "scope": "PY"
      },
      {
        "var": "volume",
        "fact_key": "sales_volume",
        "scope": "CURRENT"
      },
      {
        "var": "volume_py",
        "fact_key": "sales_volume",
        "scope": "PY"
      }
    ],
    "notes": "Approximation unless revenue, volume and realization have identical scope and mix."
  },
  "production_to_sales_ratio": {
    "name": "Production to Sales Ratio",
    "unit": "x",
    "category": "inventory_proxy",
    "formula": "production / volume",
    "inputs": [
      {
        "var": "production",
        "fact_key": "production_volume",
        "scope": "CURRENT"
      },
      {
        "var": "volume",
        "fact_key": "sales_volume",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "capacity_growth_yoy": {
    "name": "Installed Capacity YoY Growth",
    "unit": "%",
