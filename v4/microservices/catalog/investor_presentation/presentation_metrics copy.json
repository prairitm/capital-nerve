    "category": "demand",
    "formula": "order_book / (revenue * annualization_factor)",
    "inputs": [
      {
        "var": "order_book",
        "fact_key": "order_book",
        "scope": "CURRENT"
      },
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "annualization_factor",
        "constant": 4
      }
    ],
    "notes": "Use factor 4 for quarterly revenue and 1 for annual revenue."
  },
  "customer_count_yoy_growth": {
