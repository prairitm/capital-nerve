      },
      {
        "var": "utilization_py",
        "fact_key": "capacity_utilization",
        "scope": "PY"
      }
    ],
    "preserve_dimensions": true
  },
  "capacity_headroom": {
    "name": "Capacity Headroom",
    "unit": "%",
    "category": "capacity",
    "formula": "100 - utilization",
    "inputs": [
      {
        "var": "utilization",
        "fact_key": "capacity_utilization",
        "scope": "CURRENT"
      }
    ],
    "preserve_dimensions": true
  },
  "revenue_per_capacity_unit": {
    "name": "Revenue per Capacity Unit",
    "unit": "crore_per_capacity_unit",
    "category": "productivity",
    "formula": "revenue / capacity",
    "inputs": [
      {
        "var": "revenue",
        "fact_key": "revenue_from_operations",
        "scope": "CURRENT"
      },
      {
        "var": "capacity",
