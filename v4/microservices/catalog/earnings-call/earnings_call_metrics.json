        "scope": "YTD_CURRENT"
      },
      {
        "var": "remaining_quarters",
        "runtime_parameter": "remaining_quarters"
      }
    ]
  },
  "required_run_rate_premium": {
    "name": "Required Run Rate Premium",
    "unit": "%",
