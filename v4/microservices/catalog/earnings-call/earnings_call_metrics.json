    "unit": "%",
    "category": "guidance_execution",
    "formula": "reported_revenue_ytd/revenue_guidance_midpoint*100",
    "formula_type": "ARITHMETIC",
    "inputs": [
      {
        "var": "reported_revenue_ytd",
        "fact_key": "revenue_from_operations",
        "scope": "YTD_CURRENT"
      },
