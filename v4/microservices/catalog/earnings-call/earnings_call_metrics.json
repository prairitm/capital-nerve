    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "topics",
        "fact_key": "analyst_question_topic",
        "scope": "Q_AND_A"
      }
    ]
  },
  "question_intensity_change_qoq": {
    "name": "Question Intensity Change QoQ",
    "unit": "%",
    "category": "analyst_attention",
    "formula": "(current-previous)/max(previous,1)*100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "current",
        "fact_key": "analyst_question_text",
        "scope": "CALL"
      },
      {
        "var": "previous",
        "fact_key": "analyst_question_text",
        "scope": "PREVIOUS_CALL"
      }
    ]
  },
  "commitment_completion_rate": {
    "name": "Commitment Completion Rate",
    "unit": "%",
    "category": "execution",
    "formula": "achieved/evaluable*100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "status",
        "fact_key": "commitment_status",
        "scope": "ROLLING_CALL_WINDOW"
      }
    ]
  },
  "commitment_miss_rate": {
    "name": "Commitment Miss Rate",
    "unit": "%",
    "category": "execution",
    "formula": "(missed+delayed+withdrawn)/evaluable*100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "status",
        "fact_key": "commitment_status",
        "scope": "ROLLING_CALL_WINDOW"
      }
    ]
  },
  "commitment_reiteration_count": {
    "name": "Commitment Reiteration Count",
    "unit": "count",
    "category": "execution",
    "formula": "count(status==REITERATED)",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "status",
        "fact_key": "commitment_status",
        "scope": "ROLLING_CALL_WINDOW"
      }
    ]
  },
  "project_date_slippage_days": {
    "name": "Project Date Slippage Days",
    "unit": "days",
    "category": "execution",
    "formula": "date_diff(current,previous)",
    "formula_type": "DATE",
    "inputs": [
      {
        "var": "current",
        "fact_key": "commissioning_date_guidance",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "previous",
        "fact_key": "commissioning_date_guidance",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "project_cost_revision_pct": {
    "name": "Project Cost Revision Pct",
    "unit": "%",
    "category": "execution",
    "formula": "(current-previous)/abs(previous)*100",
    "formula_type": "ARITHMETIC",
    "inputs": [
      {
        "var": "current",
        "fact_key": "project_cost_revision",
        "scope": "CURRENT_DISCLOSURE"
      },
      {
        "var": "previous",
        "fact_key": "project_cost_revision",
        "scope": "PREVIOUS_DISCLOSURE"
      }
    ],
    "preserve_dimensions": true
  },
  "claim_support_rate": {
    "name": "Claim Support Rate",
    "unit": "%",
    "category": "cross_document",
    "formula": "supported_claims/verifiable_claims*100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "result_support",
        "fact_key": "claim_supported_by_result",
        "scope": "CALL"
      },
      {
        "var": "presentation_support",
        "fact_key": "claim_supported_by_presentation",
        "scope": "CALL"
      }
    ]
  },
  "current_disclosure_contradiction_count": {
    "name": "Current Disclosure Contradiction Count",
    "unit": "count",
    "category": "cross_document",
    "formula": "count(contradiction==true)",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "x",
        "fact_key": "claim_contradicts_current_disclosure",
        "scope": "CALL"
      }
    ]
  },
  "prior_call_contradiction_count": {
    "name": "Prior Call Contradiction Count",
    "unit": "count",
    "category": "cross_document",
    "formula": "count(contradiction==true)",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "x",
        "fact_key": "claim_contradicts_prior_call",
        "scope": "CALL"
      }
    ]
  },
  "explanation_coverage_ratio": {
    "name": "Explanation Coverage Ratio",
    "unit": "%",
    "category": "cross_document",
    "formula": "explained_material_movements/material_movements*100",
    "formula_type": "SEMANTIC",
    "inputs": [
      {
        "var": "movements",
        "source": "FINANCIAL_RESULT_METRICS"
      },
      {
        "var": "links",
        "fact_key": "linked_metric_key",
        "scope": "CALL"
      }
    ]
  },
  "risk_to_financial_alignment_score": {
    "name": "Risk To Financial Alignment Score",
    "unit": "score_0_to_100",
    "category": "cross_document",
    "formula": "semantic_alignment(call_risks,financial_deteriorations)",
    "formula_type": "SEMANTIC",
    "inputs": [
      {
        "var": "risks",
        "fact_key": "risk_factor",
        "scope": "CALL"
      },
      {
        "var": "financial_deteriorations",
        "source": "FINANCIAL_RESULT_SIGNALS"
      }
    ]
  },
  "guidance_to_actual_gap_pct": {
    "name": "Guidance To Actual Gap Pct",
    "unit": "%",
    "category": "cross_document",
    "formula": "(actual-guidance_midpoint)/abs(guidance_midpoint)*100",
    "formula_type": "ARITHMETIC",
    "inputs": [
      {
        "var": "actual",
        "fact_key": "revenue_from_operations",
        "scope": "TARGET_PERIOD_ACTUAL"
      },
      {
        "var": "guidance",
        "metric_key": "revenue_guidance_midpoint",
        "scope": "ORIGINAL_GUIDANCE"
      }
    ]
  },
  "management_claim_accuracy_rate": {
    "name": "Management Claim Accuracy Rate",
    "unit": "%",
    "category": "cross_document",
    "formula": "verified_forward_claims/evaluable_forward_claims*100",
    "formula_type": "AGGREGATION",
    "inputs": [
      {
        "var": "claims",
        "source": "CLAIM_TRACKING_TABLE"
      }
    ]
  },
  "topic_avoidance_score": {
    "name": "Topic Avoidance Score",
    "unit": "score_0_to_100",
    "category": "qa_quality",
    "formula": "weighted(repeated_concerns,non_responsive,unanswered)",
    "formula_type": "COMPOSITE",
    "inputs": [
      {
        "var": "repeated",
        "metric_key": "repeated_concern_count"
