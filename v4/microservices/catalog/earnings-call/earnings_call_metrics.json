      {
        "var": "nonresponsive",
        "metric_key": "non_responsive_answer_rate"
      },
      {
        "var": "unanswered",
        "metric_key": "unanswered_question_rate"
      }
    ],
    "notes": "Review prioritization only; not proof of intent."
  },
  "transcript_information_density": {
    "name": "Transcript Information Density",
    "unit": "%",
