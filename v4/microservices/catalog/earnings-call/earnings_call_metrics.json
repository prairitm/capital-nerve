    "formula_type": "COMPOSITE",
    "inputs": [
      {
        "var": "quantified",
        "metric_key": "quantified_statement_ratio"
      },
      {
        "var": "new_info",
        "metric_key": "new_information_answer_rate"
      }
    ]
  }
