  "qualified_review_conclusion": {
    "name": "Qualified Review Conclusion",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "HIGH",
    "description": "The auditor or reviewer issued a qualified conclusion.",
    "rule": {
      "fact_key": "audit_conclusion",
      "op": "==",
      "value": "QUALIFIED"
    }
  },
  "adverse_or_disclaimer_conclusion": {
    "name": "Adverse Or Disclaimer Conclusion",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "CRITICAL",
    "description": "The auditor issued an adverse conclusion or disclaimer.",
    "rule": {
      "fact_key": "audit_conclusion",
      "op": "IN",
      "value": [
        "ADVERSE",
        "DISCLAIMER"
      ]
    }
  },
  "emphasis_of_matter": {
    "name": "Emphasis Of Matter",
    "category": "audit",
    "direction": "MIXED",
    "severity": "MEDIUM",
    "description": "The report contains an emphasis-of-matter paragraph.",
    "rule": {
      "fact_key": "emphasis_of_matter_flag",
      "op": "==",
      "value": true
    }
  },
  "going_concern_risk": {
    "name": "Going Concern Risk",
    "category": "audit",
    "direction": "NEGATIVE",
    "severity": "CRITICAL",
    "description": "The auditor identified material uncertainty related to going concern.",
    "rule": {
      "fact_key": "going_concern_uncertainty_flag",
      "op": "==",
      "value": true
    }
  },
